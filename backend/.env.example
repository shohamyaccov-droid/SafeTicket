# SafeTrade Backend - Environment Variables
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.

# Required for production - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts (e.g. for production: yourdomain.com,api.yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: Database (uncomment in settings.py when using PostgreSQL)
# DB_NAME=safeticket
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Optional: Email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
