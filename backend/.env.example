# SafeTrade Backend - Environment Variables
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.

# Required for production - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-production-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts (e.g. for production: yourdomain.com,api.yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: Database (uncomment in settings.py when using PostgreSQL)
# DB_NAME=safeticket
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# Payme.io (sandbox / test — never commit real keys)
# PAYME_GENERATE_SALE_URL defaults to https://testpay.payme.io/api/generate-sale if unset.
# PAYME_WEBHOOK_SECRET: optional HMAC for /api/payments/webhook/ (empty = skip verify in dev).
# PAYME_SUB_SELLER_PAYEE_ID: Payme payee id for the ticket seller (sub_seller / split).
# PAYME_EXTRA_BODY_JSON: optional JSON object merged into generate-sale body for provider-specific fields.
PAYME_MERCHANT_ID=
PAYME_API_KEY=
PAYME_API_SECRET=
# PAYME_GENERATE_SALE_URL=https://testpay.payme.io/api/generate-sale
PAYME_WEBHOOK_SECRET=
PAYME_SUB_SELLER_PAYEE_ID=
# PAYME_EXTRA_BODY_JSON={}

# Frontend (Vite): set VITE_USE_PAYME=true to use Payme hosted checkout instead of mock card form.
# VITE_USE_PAYME=true

# Optional: Email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
